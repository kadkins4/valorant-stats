# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*

# testing
/coverage
/test-results
/playwright-report

# next.js
/.next/
/out/

# production
/build
dist/

# misc
.DS_Store
*.pem
*.log
*.bak

# debug
npm-debug.log*
yarn-debug.log*
.pnpm-debug.log*

# Secrets — never commit the API key or DB URL.
# .env.example IS committed (documents the keys).
.env
.env*.local
!.env.example

# vercel
.vercel

# Claude Code worktrees (isolated build copies) — never commit
.claude/worktrees/
.claire/

# Brainstorming visual-companion scratch files
.superpowers/

# typescript
*.tsbuildinfo
next-env.d.ts
