# HenrikDev Valorant API key (free "Basic" tier, instant approval).
# Get one: join discord.gg/HenrikDev, then create a key at https://api.henrikdev.xyz/dashboard/
# Copy this file to .env and fill in your key. .env is gitignored.
VAL_API_KEY=HDEV-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Neon serverless Postgres connection string (free tier).
# Create a project at https://neon.tech, then Dashboard → Connection string.
DATABASE_URL=postgres://USER:PASSWORD@HOST/db?sslmode=require

# Account the app tracks (defaults baked into lib/config.ts).
RIOT_NAME=ST1CCS
RIOT_TAG=STONE
REGION=na
PLATFORM=pc
